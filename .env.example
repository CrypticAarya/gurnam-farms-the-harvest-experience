# Supabase Configuration (REQUIRED)
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key

# Email Configuration (OPTIONAL)
# Get from: https://resend.com/api-keys
# If not provided, email confirmations will be disabled (graceful fallback)
RESEND_API_KEY=re_xxxxxxxxx

# Error Tracking (OPTIONAL)
# Get from: https://sentry.io
# If not provided, Sentry will be disabled (graceful fallback)
VITE_SENTRY_DSN=https://key@sentry.io/project

# Notes:
# - All VITE_* variables are exposed to frontend (don't put secrets there)
# - RESEND_API_KEY is server-only (safe to use in server functions)
# - This file is for local development only
# - Production: Set variables in Vercel/deployment platform
