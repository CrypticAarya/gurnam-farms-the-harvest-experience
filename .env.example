### Gurnam Farms - Example environment variables
# Copy this file to `.env` for local development. NEVER commit real secrets.

# Public VITE_ variables are exposed to client-side code via Vite.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=anon-your-anon-key

# Optional/public observability
VITE_SENTRY_DSN=https://examplePublicKey@sentry.io/project_id

# Email provider (optional): e.g. "resend", "sendgrid"
VITE_EMAIL_PROVIDER=resend

# Server-side secrets (do NOT use VITE_ prefix for secrets)
RESEND_API_KEY=sk-your-resend-api-key

# Typical runtime
NODE_ENV=development

# Optional: if using a managed Postgres or other DB
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# STRIPE_SECRET_KEY=sk_test_...

# Notes:
# - VITE_* variables are available in client and server builds.
# - Server-only secrets (like RESEND_API_KEY) must be configured in your deployment platform.# Supabase Configuration (REQUIRED)
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFwd3B1emx4YWNpbGpveG1reG1wIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA1MDUwNjksImV4cCI6MjA5NjA4MTA2OX0.cRvfjZIbUOGIHFGOt5JhJzH9w3q3qbl4_TZPTicC0JA

# Email Configuration (OPTIONAL)
# Get from: https://resend.com/api-keys
# If not provided, email confirmations will be disabled (graceful fallback)
RESEND_API_KEY=re_xxxxxxxxx

# Error Tracking (OPTIONAL)
# Get from: https://sentry.io
# If not provided, Sentry will be disabled (graceful fallback)
VITE_SENTRY_DSN=https://key@sentry.io/project

# Notes:
# - All VITE_* variables are exposed to frontend (don't put secrets there)
# - RESEND_API_KEY is server-only (safe to use in server functions)
# - This file is for local development only
# - Production: Set variables in Vercel/deployment platform
